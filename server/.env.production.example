# ─── 唐小识后端 - 生产环境变量 ───
# 这是给 CloudBase 云托管的模板,**不要把真实值写进这个文件**
# 真实密钥在 CloudBase 控制台 → 云托管 → 服务 → 环境变量 里配置

# 监听端口(CloudBase 会自动注入 PORT,这里只是兜底)
PORT=3000

# Node 运行环境
NODE_ENV=production

# ─── 必填:数据库(Supabase / 兼容 Postgres)───
COZE_SUPABASE_URL=
COZE_SUPABASE_ANON_KEY=
COZE_SUPABASE_SERVICE_ROLE_KEY=

# ─── 必填:微信小程序登录 ───
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ─── 必填:火山引擎 TOS 对象存储 ───
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=
TOS_PUBLIC_BASE_URL=

# ─── 可选 ───
# 腾讯位置服务 WebServiceAPI Key(用于里程计算)
LOCATION_APIKEY=

# 首次启动时自动创建管理员账号(只需首次部署设置一次,然后删除)
# INIT_ADMIN_USERNAME=admin
# INIT_ADMIN_PASSWORD=change-me-now

# ─── 安全相关(生产必须设置) ───
# 生产必须关闭开发身份登录
ENABLE_DEV_AUTH=false

# 允许的管理员端跨域来源(逗号分隔)。
# 例如 CloudBase 静态托管给的域名 https://xxx-xxx.tcloudbaseapp.com
# 多个域名用逗号分隔,不要带末尾斜杠
ADMIN_ALLOWED_ORIGINS=https://your-admin-static-host.example.com