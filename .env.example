# 腾讯位置服务 WebServiceAPI Key
# 申请地址: https://lbs.qq.com/dev/console/application/mine
# 启用 WebServiceAPI 服务，将 Key 填入下方
LOCATION_APIKEY=your_location_api_key_here
SQLITE_DB_PATH=./server/data/app.db
SQLITE_BUSY_TIMEOUT_MS=5000
# 管理后台数据源；本地一键命令会自动设为 sqlite，生产必须为 supabase
ADMIN_DATA_BACKEND=supabase
ADMIN_SQLITE_DB_PATH=./server/data/admin-local.sqlite
# 仅 SQLite 本地演示模式使用，可覆盖默认演示账号
# LOCAL_ADMIN_USERNAME=wjf
# LOCAL_ADMIN_PASSWORD=123
ENABLE_DEV_AUTH=true
# 生产环境必须为 production，且开发身份会自动禁用
NODE_ENV=development
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# INIT_ADMIN_USERNAME=
# INIT_ADMIN_PASSWORD=
ADMIN_ALLOWED_ORIGINS=http://localhost:5174
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=
TOS_PUBLIC_BASE_URL=
# 可选：数据库备份输出目录，默认 server/backups
SQLITE_BACKUP_DIR=./server/backups
