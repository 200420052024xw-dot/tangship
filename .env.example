# 腾讯位置服务 WebService API Key
LOCATION_APIKEY=your_location_api_key_here

# 扣子编程 Supabase 数据库
COZE_SUPABASE_URL=
COZE_SUPABASE_ANON_KEY=
COZE_SUPABASE_SERVICE_ROLE_KEY=

# 开发身份登录仅用于本地开发，生产环境必须关闭
ENABLE_DEV_AUTH=true
NODE_ENV=development

# 微信小程序配置；AppSecret 仅允许保存在服务端
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 可选：首次启动时创建管理员
# INIT_ADMIN_USERNAME=
# INIT_ADMIN_PASSWORD=

ADMIN_ALLOWED_ORIGINS=http://localhost:5174

# 火山引擎 TOS 对象存储
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_REGION=cn-beijing
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_BUCKET=
TOS_PUBLIC_BASE_URL=
