# ─── 管理员端 - 构建期环境变量 ───
# Vite 会在 build 时把这些值注入到产物里(.env.production 只在 build 时读取)
#
# 用法:
#   cp .env.production.example .env.production
#   修改 VITE_API_BASE_URL 为后端 CloudBase 云托管的 URL(末尾不要带 /api,vite.config 已处理)
#   pnpm build:admin

# 后端 CloudBase 云托管 URL(示例:https://tangshi-api-xxxxxx.ap-shanghai.app.tcloudbase.com)
VITE_API_BASE_URL=https://your-cloudbase-run-host.example.com